---
const plans = [
  {
    name: 'Пробный',
    price: 0,
    priceLabel: 'Бесплатно',
    period: 'первый урок',
    color: '#F07B1F',
    features: [
      'Любое направление',
      'Полноценное занятие',
      'Все материалы включены',
      'Без обязательств',
    ],
    cta: 'Записаться',
    highlight: false,
  },
  {
    name: 'Стартовый',
    price: 3700,
    priceLabel: '3 700 ₽',
    period: '4 занятия',
    color: '#2196F3',
    features: [
      'Лепка или рисование',
      '45 мин/занятие',
      'Все материалы включены',
      'Перенос пропусков',
    ],
    cta: 'Выбрать',
    highlight: false,
  },
  {
    name: 'Оптимальный',
    price: 6800,
    priceLabel: '6 800 ₽',
    period: '8 занятий',
    color: '#F07B1F',
    features: [
      'Любое направление',
      '60 мин/занятие',
      'Все материалы включены',
      'Перенос пропусков',
      'Скидка 8%',
    ],
    cta: 'Выбрать',
    highlight: true,
  },
  {
    name: 'Максимум',
    price: 12000,
    priceLabel: '12 000 ₽',
    period: '16 занятий',
    color: '#4CAF50',
    features: [
      'Любое направление',
      '90 мин/занятие',
      'Все материалы включены',
      'Перенос пропусков',
      'Скидка 15%',
      'Приоритетная запись',
    ],
    cta: 'Выбрать',
    highlight: false,
  },
];
---
<section class="pricing" id="pricing">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Стоимость</span>
      <h2>Выберите подходящий абонемент</h2>
      <p class="section-desc">Все материалы включены в стоимость. Пропущенные занятия переносятся.</p>
    </div>
    <div class="pricing__grid">
      {plans.map(p => (
        <div class={`pricing-card${p.highlight ? ' pricing-card--highlight' : ''}`} style={`--accent:${p.color}`}>
          {p.highlight && <div class="pricing-card__badge">Популярный</div>}
          <div class="pricing-card__name">{p.name}</div>
          <div class="pricing-card__price">{p.priceLabel}</div>
          <div class="pricing-card__period">{p.period}</div>
          <ul class="pricing-card__features">
            {p.features.map(f => <li>✓ {f}</li>)}
          </ul>
          <a href="#enrollment" class={`btn ${p.highlight ? 'btn-orange' : 'btn-outline'} pricing-card__cta`}>{p.cta}</a>
        </div>
      ))}
    </div>
    <p class="pricing__note">Индивидуальные занятия и праздники рассчитываются отдельно. <a href="#contacts">Спросить менеджера →</a></p>
  </div>
</section>

<style>
  .pricing {
    background: linear-gradient(180deg, #fff 0%, #FFF8F2 100%);
  }

  .section-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .section-desc {
    font-size: 19px;
    color: var(--text-light);
    max-width: 500px;
    margin: 0 auto;
  }

  .pricing__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    align-items: stretch;
    padding-top: 16px;
  }

  .pricing-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    border: 2px solid #F0F0F0;
    border-radius: var(--radius);
    padding: 32px 24px;
    position: relative;
    transition: transform 0.2s, box-shadow 0.2s;
    background: #fff;
  }

  .pricing-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.08);
  }

  .pricing-card--highlight {
    border-color: var(--orange);
    background: linear-gradient(135deg, #FFF8F2, #fff);
    box-shadow: 0 8px 32px rgba(240, 123, 31, 0.12);
  }

  .pricing-card--highlight:hover { transform: translateY(-4px); }

  .pricing-card__badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--orange);
    color: #fff;
    font-size: 16px;
    font-weight: 800;
    padding: 4px 16px;
    border-radius: 50px;
    white-space: nowrap;
  }

  .pricing-card__name {
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .pricing-card__price {
    font-size: 40px;
    font-weight: 900;
    line-height: 1;
    margin-bottom: 4px;
  }

  .pricing-card__period {
    font-size: 15px;
    color: var(--text-light);
    font-weight: 600;
    margin-bottom: 24px;
  }

  .pricing-card__features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
    margin-bottom: 28px;
    padding-bottom: 24px;
    border-bottom: 1px solid #F0F0F0;
  }

  .pricing-card__features li {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-light);
  }

  .pricing-card__cta { width: 100%; text-align: center; }

  .pricing__note {
    text-align: center;
    margin-top: 40px;
    font-size: 17px;
    color: var(--text-light);
  }

  .pricing__note a {
    color: var(--orange);
    font-weight: 700;
  }

  @media (max-width: 1000px) {
    .pricing__grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 600px) {
    .pricing__grid { grid-template-columns: 1fr; }
  }
</style>
