---
---
<section class="hero">
  <div class="container hero__inner">
    <div class="hero__content">
      <div class="hero__badge">Санкт-Петербург · 3 студии</div>
      <h1 class="hero__title">Школа лепки<br />и рисования</h1>
      <p class="hero__sub">для детей <strong>3–11 лет</strong></p>
      <p class="hero__desc">Раскрываем творческий потенциал каждого ребёнка через лепку, рисование и живопись в уютной атмосфере.</p>
      <div class="hero__actions">
        <a href="#enrollment" class="btn btn-orange hero__cta">Первый урок бесплатно</a>
        <a href="#services" class="btn btn-outline">Узнать об услугах</a>
      </div>
      <div class="hero__stats">
        <div class="stat">
          <span class="stat__num">6–8</span>
          <span class="stat__label">детей в группе</span>
        </div>
        <div class="stat">
          <span class="stat__num">3+</span>
          <span class="stat__label">года работаем</span>
        </div>
        <div class="stat">
          <span class="stat__num">500+</span>
          <span class="stat__label">выпускников</span>
        </div>
      </div>
    </div>
    <div class="hero__visual">
      <div class="hero__blob">
        <div class="hero__img-wrap">
          <img
            src="https://thb.tildacdn.com/tild6632-3262-4830-b938-376430626534/-/resize/600x/deti_glav_mob3.jpg"
            alt="Дети на занятии в Оранжерее"
            width="500"
            height="560"
          />
        </div>
        <div class="hero__card hero__card--1">
          <span>🎨</span> Творческая среда
        </div>
        <div class="hero__card hero__card--2">
          <span>🏆</span> Опытные педагоги
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, #FFF8F2 0%, #FFF3E5 60%, #FFF8F2 100%);
    padding: 60px 0 80px;
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--orange);
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    padding: 6px 16px;
    border-radius: 50px;
    margin-bottom: 20px;
  }

  .hero__title {
    font-size: clamp(38px, 5vw, 60px);
    font-weight: 900;
    line-height: 1.1;
    color: var(--text);
    margin-bottom: 8px;
  }

  .hero__sub {
    font-size: 24px;
    font-weight: 700;
    color: var(--orange);
    margin-bottom: 20px;
  }

  .hero__desc {
    font-size: 17px;
    color: var(--text-light);
    margin-bottom: 36px;
    max-width: 440px;
    line-height: 1.65;
  }

  .hero__actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }

  .hero__cta { font-size: 16px; padding: 16px 36px; }

  .hero__stats {
    display: flex;
    gap: 36px;
  }

  .stat { display: flex; flex-direction: column; }

  .stat__num {
    font-size: 32px;
    font-weight: 900;
    color: var(--orange);
    line-height: 1;
  }

  .stat__label {
    font-size: 13px;
    color: var(--text-light);
    font-weight: 600;
    margin-top: 4px;
  }

  .hero__visual { position: relative; }

  .hero__blob {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .hero__img-wrap {
    width: 440px;
    height: 500px;
    border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
    overflow: hidden;
    background: #e8d5c0;
  }

  .hero__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .hero__card {
    position: absolute;
    background: #fff;
    border-radius: 12px;
    padding: 12px 18px;
    font-weight: 700;
    font-size: 14px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    display: flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
  }

  .hero__card--1 { bottom: 60px; left: -20px; }
  .hero__card--2 { top: 60px; right: -20px; }

  @media (max-width: 900px) {
    .hero__inner { grid-template-columns: 1fr; gap: 40px; }
    .hero__visual { display: none; }
    .hero__stats { gap: 24px; }
  }
</style>
